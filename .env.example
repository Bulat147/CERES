# Database
DATABASE_TYPE=sqlite

# PostgreSQL settings (используются только если DATABASE_TYPE=postgresql)
POSTGRES_SERVER=localhost
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=ceres_db
POSTGRES_PORT=5432

# SQLite settings (используются только если DATABASE_TYPE=sqlite)
SQLITE_DB_PATH=sqlite+aiosqlite:///./ceres.db

# JWT (for future authentication)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Payment providers (optional)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080