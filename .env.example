# Database (PostgreSQL)
DATABASE_TYPE=postgresql

# localhost — запуск API на хосте; db — внутри docker compose
POSTGRES_SERVER=localhost
POSTGRES_USER=user
POSTGRES_PASSWORD=P@ssw0rd
POSTGRES_DB=main
POSTGRES_PORT=5432

# При старте контейнера: alembic upgrade head (создание таблиц)
RUN_DB_MIGRATIONS=true

# SQLite (только если DATABASE_TYPE=sqlite)
# SQLITE_DB_PATH=sqlite+aiosqlite:///./ceres.db

# JWT (for future authentication)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Payment providers (optional)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Prometheus /metrics (true по умолчанию)
ENABLE_METRICS=true

# Grafana (docker-compose.monitoring.yaml)
GRAFANA_ADMIN_PASSWORD=admin