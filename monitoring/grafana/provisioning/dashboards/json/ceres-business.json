  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "ceres_active_rentals", "refId": "A" }],
      "title": "Активные аренды",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "ceres_available_cells", "refId": "A" }],
      "title": "Свободные ячейки",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "ceres_active_rentals + ceres_available_cells",
          "refId": "A"
        }
      ],
      "title": "Ячеек в учёте (active + available)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(ceres_rentals_created_total[5m])) * 60",
          "legendFormat": "новые аренды/мин",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ceres_rentals_started_total[5m])) * 60",
          "legendFormat": "старт аренды/мин",
          "refId": "B"
        },
        {
          "expr": "sum(rate(ceres_payments_created_total[5m])) by (status) * 60",
          "legendFormat": "платежи {{status}}/мин",
          "refId": "C"
        }
      ],
      "title": "Бизнес-события",
      "type": "timeseries"
    }
  ],
