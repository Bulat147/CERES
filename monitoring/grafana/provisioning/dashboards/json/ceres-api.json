      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 * sum(rate(ceres_db_requests_total{status=\"success\"}[5m])) / clamp_min(sum(rate(ceres_db_requests_total[5m])), 0.001)",
          "legendFormat": "успешность %",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ceres_db_requests_total{status=\"error\"}[5m]))",
          "legendFormat": "ошибки/с",
          "refId": "B"
        }
      ],
